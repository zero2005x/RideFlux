<!--
  RideFlux word-mark / brand vector.
  Horizontal layout: tire-with-bolt icon followed by "RideFlux"
  in a geometric bold face synthesised as vector paths so there is
  zero font dependency at runtime.

  Designed to render well at any size from 32dp up to 256dp — e.g.
  app-bar branding, splash screen, about dialog.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="240dp"
    android:height="64dp"
    android:viewportWidth="240"
    android:viewportHeight="64">

    <!-- Icon mark -->
    <path
        android:pathData="M32,8 A24,24 0 1 1 31.999,8 Z"
        android:strokeColor="#00E5FF"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />
    <path
        android:pathData="M34,18 L24,36 L30,36 L28,48 L40,32 L34,32 Z"
        android:fillColor="#FFFFFFFF" />

    <!-- Wordmark "RideFlux" — rendered as filled silhouette paths. -->
    <!-- R -->
    <path
        android:pathData="M72,18 h10 a8,8 0 0 1 0,16 h-6 l8,12 h-6 l-7,-11 h-3 v11 h-5 v-28 h9 Z M72,22 v10 h5 a5,5 0 0 0 0,-10 Z"
        android:fillColor="#FFFFFFFF" />
    <!-- i -->
    <path
        android:pathData="M92,18 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0 M90,26 h5 v20 h-5 Z"
        android:fillColor="#FFFFFFFF" />
    <!-- d -->
    <path
        android:pathData="M114,18 h-5 v10 q-3,-3 -7,-3 a10,10 0 0 0 0,20 q4,0 7,-3 v2 h5 Z M104,40 a5,5 0 1,1 5,-5 a5,5 0 0 1 -5,5 Z"
        android:fillColor="#FFFFFFFF" />
    <!-- e -->
    <path
        android:pathData="M130,25 a10,10 0 0 1 10,10 v2 h-15 a5,5 0 0 0 9,2 h5 a10,10 0 0 1 -19,-4 a10,10 0 0 1 10,-10 Z M125,33 h10 a5,5 0 0 0 -10,0 Z"
        android:fillColor="#FFFFFFFF" />

    <!-- F (cyan accent) -->
    <path
        android:pathData="M154,18 h16 v4 h-11 v8 h9 v4 h-9 v12 h-5 Z"
        android:fillColor="#00E5FF" />
    <!-- l -->
    <path
        android:pathData="M174,18 h5 v28 h-5 Z"
        android:fillColor="#00E5FF" />
    <!-- u -->
    <path
        android:pathData="M184,26 h5 v11 a3,3 0 0 0 6,0 v-11 h5 v20 h-5 v-2 q-2,3 -6,3 a6,6 0 0 1 -5,-6 Z"
        android:fillColor="#00E5FF" />
    <!-- x -->
    <path
        android:pathData="M209,26 h5 l3,5 l3,-5 h5 l-5,9 l6,11 h-5 l-4,-6 l-4,6 h-5 l6,-11 Z"
        android:fillColor="#00E5FF" />

</vector>
