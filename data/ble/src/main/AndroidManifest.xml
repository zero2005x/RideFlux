<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Permission declarations for Android BLE. The runtime permission
      prompts (BLUETOOTH_SCAN / BLUETOOTH_CONNECT on API 31+, and
      ACCESS_FINE_LOCATION on earlier releases) are the responsibility
      of the :app module; we only declare them here so that linkages
      into library consumers do not require a separate manifest merge
      step.
    -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s"
        xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s"
        xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

</manifest>
